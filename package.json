{
  "name": "fastify-backend",
  "version": "2.3.7",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "start": "npm run build:ts && node dist/server.js",
    "build:ts": "tsc && tsc-alias",
    "watch:ts": "tsc -w",
    "dev": "tsx watch src/server.ts",
    "dev:doppler": "doppler run -- npm run dev",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/server.js",
    "secret_key": "node generateSecretKey.js",
    "encrypt": "node generateEncryption.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/fastify": "^3.1.40",
    "@fastify/autoload": "^6.0.0",
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.11.1",
    "mongoose": "^9.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.0.3",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.4.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  }
}
